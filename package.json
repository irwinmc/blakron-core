{
	"name": "@heron/core",
	"version": "0.2.0",
	"description": "Egret Next",
	"author": "",
	"license": "MIT",
	"type": "module",
	"main": ".dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist/**/*",
		"types/**/*"
	],
	"scripts": {
		"build": "tsc --build && npm run build:types",
		"build:types": "tsc --emitDeclarationOnly --declaration --declarationMap",
		"dev": "tsc --watch",
		"clean": "rm -rf dist",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"happy-dom": "^20.8.9",
		"typescript": "^5.6.0",
		"vitest": "^4.1.4"
	},
	"keywords": [
		"heron",
		"h5-game",
		"webgl",
		"webgpu",
		"typescript"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/irwinmc/Heron.git"
	},
	"packageManager": "pnpm@10.33.0"
}
