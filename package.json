{
	"name": "@blakron/core",
	"version": "0.3.0",
	"description": "Modern rewrite of the Egret game engine — WebGL multi-texture batching, instruction-driven render pipeline, strict TypeScript, Egret-compatible API",
	"author": "",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist/**/*",
		"types/**/*"
	],
	"scripts": {
		"build": "tsc --build && npm run build:types",
		"build:types": "tsc --emitDeclarationOnly --declaration --declarationMap",
		"dev": "tsc --watch",
		"clean": "rm -rf dist",
		"test": "vitest run",
		"test:watch": "vitest",
		"benchmark": "vite --config vite.config.ts --open /index.html",
		"build:benchmark": "vite --config vite.config.ts build && cp examples/egret.min.js examples/egret.web.min.js benchmark-dist/",
		"preview:benchmark": "vite preview --config vite.config.ts --host 0.0.0.0 --port 4173"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"fast-check": "^4.6.0",
		"happy-dom": "^20.8.9",
		"typescript": "^5.6.0",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	},
	"keywords": [
		"blakron",
		"h5-game",
		"webgl",
		"webgpu",
		"typescript"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/irwinmc/blakron-core.git"
	},
	"packageManager": "pnpm@10.33.0"
}
